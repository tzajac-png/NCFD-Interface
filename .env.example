# --- Spreadsheet (defaults match the NCFD link-shared sheet) ---
# https://docs.google.com/spreadsheets/d/12H7qOkmveAYnSYBvB1AihnEZ3YfwoLvRL6Akb1TKrq8/edit
VITE_SPREADSHEET_ID=12H7qOkmveAYnSYBvB1AihnEZ3YfwoLvRL6Akb1TKrq8
VITE_SHEET_GID=197752573
# Optional: fixed range instead of resolving tab by gid:
# VITE_SHEET_RANGE=Sheet1!A:ZZ

# With “Anyone with the link can view”, the app loads CSV via Google’s export URL (read-only).
# npm run dev / vite preview: Vite proxies /gdoc-csv → docs.google.com.
# Vercel / Netlify: use the included vercel.json or netlify.toml rewrites.
# Optional overrides:
# VITE_SHEETS_CSV_URL=https://...   (custom published or export URL)
# VITE_GOOGLE_SHEETS_API_KEY=...    (Sheets API if you prefer; still read-only in this app)

# Optional logo URL (default /logo.png in public/)
# VITE_LOGO_URL=/logo.png
